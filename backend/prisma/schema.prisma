// ============================================================
// Schema de Prisma - Sistema de Gestión de Inventario
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Modelo: Location (Ubicación)
// Representa una bodega, tienda u otro punto de almacenamiento
// ============================================================
model Location {
  id        String   @id @default(uuid())
  name      String
  type      String   // Ej: "bodega", "tienda", "almacen"
  capacity  Int?     // Capacidad máxima opcional (unidades)
  createdAt DateTime @default(now())
  dispatchStart String @default("8:00")
  dispatchEnd String @default("18:00")

  // Relaciones
  stocks    Stock[]
  movements Movement[]
  reservations Reservation[]
  orderItems OrderItem[]

  @@map("locations")
}

// ============================================================
// Modelo: Product (Producto)
// Representa un artículo del inventario
// ============================================================
model Product {
  id        String   @id @default(uuid())
  name      String
  sku       String   @unique // Código único del producto
  createdAt DateTime @default(now())

  // Relaciones
  stocks     Stock[]
  movements  Movement[]
  orderItems OrderItem[]

  @@map("products")
}

// ============================================================
// Modelo: Stock
// Cantidad actual de un producto en una ubicación específica
// ============================================================
model Stock {
  id         String   @id @default(uuid())
  productId  String
  locationId String
  quantity   Int      @default(0)
  reserved   Int      @default(0) // Unidades reservadas por pedidos activos

  // Relaciones
  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  // Restricción: solo puede existir un registro por producto+ubicación
  @@unique([productId, locationId])
  @@map("stocks")
}

// ============================================================
// Modelo: Movement (Movimiento)
// Registra cada entrada o salida de inventario
// ============================================================
model Movement {
  id            String       @id @default(uuid())
  productId     String
  locationId    String
  type          MovementType // "IN" = entrada, "OUT" = salida
  quantity      Int
  note          String?      // Nota opcional del movimiento
  reservationId Int?         // Vincula venta confirmada con reserva (SCRUM-33)
  createdAt     DateTime     @default(now())

  // Relaciones
  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@map("movements")
}

// ============================================================
// Modelo: Order (Pedido de salida)
// Representa una solicitud de despacho de productos a un cliente
// ============================================================
model Order {
  id           String      @id @default(uuid())
  customerName String
  status       OrderStatus @default(PENDING)
  routeId      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relaciones
  items             OrderItem[]
  dispatchSchedules DispatchSchedule[]
  route             Route?              @relation(fields: [routeId], references: [id], onDelete: SetNull)

  @@map("orders")
}

// ============================================================
// Modelo: OrderItem (Ítem de pedido)
// Producto + ubicación origen + cantidad dentro de un pedido
// ============================================================
model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  productId  String
  locationId String
  quantity   Int

  // Relaciones
  order    Order    @relation(fields: [orderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("order_items")
}

// ============================================================
// Enum: MovementType
// ============================================================
enum MovementType {
  IN  // Entrada de mercancía
  OUT // Salida de mercancía
}

enum ReservationStatus {
  ACTIVE   // Bloquea stock disponible
  RELEASED // Cancelada y liberada (stock disponible restaurado)
  SOLD     // Entrega confirmada por Proyecto 2 — stock físico descontado
  EXPIRED  // Reserva vencida (TTL) — pendiente de job automático
}

model Reservation {
  reservationId Int               @id @default(autoincrement())
  orderId       Int
  sku           String
  locationId    String
  quantity      Int
  status        ReservationStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  expiresAt     DateTime
  releasedAt    DateTime?
  soldAt        DateTime?

  location Location @relation(fields: [locationId], references: [id])
}

enum Priority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model DispatchSchedule {
  scheduleId   Int      @id @default(autoincrement())
  orderId      String
  scheduleDate DateTime
  startTime    String
  endTime      String
  status       String
  priority     String   @default("NORMAL")
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("dispatch_schedules")
}

// ============================================================
// Enum: OrderStatus
// ============================================================
enum OrderStatus {
  PENDING            // Pedido recién creado
  RESERVED           // Stock reservado correctamente
  READY_FOR_DISPATCH // Listo para asignar despacho/ruta
  ROUTE_ASSIGNED     // Asignado a una ruta de despacho
  IN_TRANSIT         // Pedido despachado (stock descontado)
  DELIVERED          // Entrega completada
  CANCELLED          // Pedido cancelado
}

// ============================================================
// Enum: RouteStatus
// ============================================================
enum RouteStatus {
  OPEN       // Ruta abierta, aceptando órdenes
  DISPATCHED // Ruta despachada (todas las órdenes en tránsito)
  CANCELLED  // Ruta cancelada (órdenes liberadas de vuelta a READY_FOR_DISPATCH)
  COMPLETED  // Todas las órdenes entregadas (estado terminal)
}

// ============================================================
// Modelo: Route (Ruta de despacho)
// Agrupa órdenes READY_FOR_DISPATCH en un viaje operativo
// ============================================================
model Route {
  id          String      @id @default(cuid())
  vehicleCode String
  driverName  String?
  status      RouteStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders Order[]

  @@map("routes")
}
