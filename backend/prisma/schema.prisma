// ============================================================
// Schema de Prisma - Sistema de Gestión de Inventario
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Modelo: Location (Ubicación)
// Representa una bodega, tienda u otro punto de almacenamiento
// ============================================================
model Location {
  id        String   @id @default(uuid())
  name      String
  type      String   // Ej: "bodega", "tienda", "almacen"
  capacity  Int?     // Capacidad máxima opcional (unidades)
  createdAt DateTime @default(now())
  dispatchStart    String @default("8:00")
  dispatchEnd      String @default("18:00")
  maxDailyDispatch Int    @default(100)
  priority         Int    @default(5)  // 1 = mayor prioridad, 10 = menor prioridad

  // Relaciones
  stocks              Stock[]
  movements           Movement[]
  reservations        Reservation[]
  orderItems          OrderItem[]
  stockAlerts         StockAlert[]
  replenishmentOrders ReplenishmentOrder[]
  physicalCounts      PhysicalCount[]

  @@map("locations")
}

// ============================================================
// Modelo: Product (Producto)
// Representa un artículo del inventario
// ============================================================
model Product {
  id        String   @id @default(uuid())
  name      String
  sku       String   @unique // Código único del producto
  minStock  Int      @default(5) // Umbral de stock crítico
  createdAt DateTime @default(now())

  // Relaciones
  stocks              Stock[]
  movements           Movement[]
  orderItems          OrderItem[]
  stockAlerts         StockAlert[]
  replenishmentOrders ReplenishmentOrder[]
  physicalCounts      PhysicalCount[]

  @@map("products")
}

// ============================================================
// Modelo: Stock
// Cantidad actual de un producto en una ubicación específica
// ============================================================
model Stock {
  id         String   @id @default(uuid())
  productId  String
  locationId String
  quantity   Int      @default(0)
  reserved   Int      @default(0) // Unidades reservadas por pedidos activos

  // Relaciones
  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  // Restricción: solo puede existir un registro por producto+ubicación
  @@unique([productId, locationId])
  @@map("stocks")
}

// ============================================================
// Modelo: Movement (Movimiento)
// Registra cada entrada o salida de inventario
// ============================================================
model Movement {
  id                    String       @id @default(uuid())
  productId             String
  locationId            String
  destinationLocationId String?      // ID de bodega destino para transferencias
  type                  MovementType // "IN" = entrada, "OUT" = salida, "TRANSFER", "RETURN"
  quantity              Int
  note                  String?      // Nota opcional del movimiento
  reservationId         Int?         // Vincula venta confirmada con reserva (SCRUM-33)
  relatedMovementId     String?      // ID de movimiento relacionado (ej: devolución)
  createdAt             DateTime     @default(now())

  // Relaciones
  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@map("movements")
}

// ============================================================
// Modelo: Order (Pedido de salida)
// Representa una solicitud de despacho de productos a un cliente
// ============================================================
model Order {
  id           String      @id @default(uuid())
  customerName String
  status       OrderStatus @default(PENDING)
  routeId      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relaciones
  items             OrderItem[]
  dispatchSchedules DispatchSchedule[]
  route             Route?              @relation(fields: [routeId], references: [id], onDelete: SetNull)

  @@map("orders")
}

// ============================================================
// Modelo: OrderItem (Ítem de pedido)
// Producto + ubicación origen + cantidad dentro de un pedido
// ============================================================
model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  productId  String
  locationId String
  quantity   Int

  // Relaciones
  order    Order    @relation(fields: [orderId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("order_items")
}

// ============================================================
// Enum: MovementType
// ============================================================
enum MovementType {
  IN       // Entrada de mercancía
  OUT      // Salida de mercancía
  TRANSFER // Transferencia de mercancía entre ubicaciones
  RETURN   // Devolución de mercancía
}

enum ReservationStatus {
  ACTIVE   // Bloquea stock disponible
  RELEASED // Cancelada y liberada (stock disponible restaurado)
  SOLD     // Entrega confirmada por Proyecto 2 — stock físico descontado
  EXPIRED  // Reserva vencida (TTL) — pendiente de job automático
}

model Reservation {
  reservationId Int               @id @default(autoincrement())
  orderId       String            // UUID v4 del pedido externo (Grupo 3)
  sku           String
  locationId    String
  quantity      Int
  status        ReservationStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  expiresAt     DateTime
  releasedAt    DateTime?
  soldAt        DateTime?

  location Location @relation(fields: [locationId], references: [id])
}

enum Priority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model DispatchSchedule {
  scheduleId   Int      @id @default(autoincrement())
  orderId      String
  scheduleDate DateTime
  startTime    String
  endTime      String
  status       String
  priority     String   @default("NORMAL")
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("dispatch_schedules")
}

// ============================================================
// Enum: OrderStatus
// ============================================================
enum OrderStatus {
  PENDING            // Pedido recién creado
  RESERVED           // Stock reservado correctamente
  READY_FOR_DISPATCH // Listo para asignar despacho/ruta
  ROUTE_ASSIGNED     // Asignado a una ruta de despacho
  IN_TRANSIT         // Pedido despachado (stock descontado)
  DELIVERED          // Entrega completada
  CANCELLED          // Pedido cancelado
}

// ============================================================
// Enum: RouteStatus
// ============================================================
enum RouteStatus {
  OPEN       // Ruta abierta, aceptando órdenes
  DISPATCHED // Ruta despachada (todas las órdenes en tránsito)
  CANCELLED  // Ruta cancelada (órdenes liberadas de vuelta a READY_FOR_DISPATCH)
  COMPLETED  // Todas las órdenes entregadas (estado terminal)
}

// ============================================================
// Modelo: Route (Ruta de despacho)
// Agrupa órdenes READY_FOR_DISPATCH en un viaje operativo
// ============================================================
model Route {
  id          String      @id @default(cuid())
  vehicleCode String
  driverName  String?
  status      RouteStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders Order[]

  @@map("routes")
}

// ============================================================
// Modelo: StockAlert (Alerta de Stock Crítico)
// ============================================================
model StockAlert {
  id           String      @id @default(uuid())
  productId    String
  locationId   String
  currentStock Int
  minStock     Int
  status       AlertStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  resolvedAt   DateTime?

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@map("stock_alerts")
}

enum AlertStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ============================================================
// Modelo: Supplier (Proveedor)
// ============================================================
model Supplier {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String?
  leadTimeDays Int      @default(7)
  createdAt    DateTime @default(now())

  replenishmentOrders ReplenishmentOrder[]
  @@map("suppliers")
}

// ============================================================
// Modelo: ReplenishmentOrder (Orden de Reposición / Compra)
// ============================================================
model ReplenishmentOrder {
  id          String              @id @default(uuid())
  productId   String
  locationId  String
  supplierId  String
  quantity    Int
  status      ReplenishmentStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("replenishment_orders")
}

enum ReplenishmentStatus {
  PROPOSED
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

// ============================================================
// Modelo: PhysicalCount — conteo físico para conciliación
// ============================================================
model PhysicalCount {
  id         String   @id @default(uuid())
  productId  String
  locationId String
  countedQty Int
  countedAt  DateTime @default(now())
  countedBy  String?
  note       String?
  period     String   // ej. "2026-06"

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId, period])
  @@map("physical_counts")
}

// ============================================================
// Modelo: OutboundEvent — cola outbox para sync con Analítica
// ============================================================
enum EventStatus {
  PENDING
  SENT
  FAILED
  DEAD
}

model OutboundEvent {
  id             String      @id @default(uuid())
  eventType      String
  payload        Json
  status         EventStatus @default(PENDING)
  attempts       Int         @default(0)
  maxAttempts    Int         @default(5)
  nextRetryAt    DateTime    @default(now())
  lastError      String?
  idempotencyKey String?     @unique
  createdAt      DateTime    @default(now())
  sentAt         DateTime?

  @@index([status, nextRetryAt])
  @@map("outbound_events")
}
