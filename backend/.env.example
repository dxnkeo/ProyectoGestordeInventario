# Variables de entorno para el Sistema de Gestión de Inventario

# Cadena de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:1624@localhost:5432/GestorInventario?schema=public"

# Puerto del servidor Express
PORT=3000

# Entorno de ejecución (development | production | test)
NODE_ENV=development

# Timezone para validaciones horarias de despacho
# Debe ser un identificador IANA válido (ej: America/Santiago, UTC, America/Bogota)
APP_TIMEZONE=America/Santiago

# Integración Grupo 3 (Pedidos) — compartir por canal seguro
EXTERNAL_API_KEY=genera-una-clave-segura-aqui

# Reservas: TTL por defecto (minutos) e intervalo del job de expiración (ms)
RESERVATION_TTL_MINUTES=30
RESERVATION_EXPIRY_INTERVAL_MS=60000

# Outbox eventos — Grupo 9 Analítica (opcional en dev)
# ANALYTICS_EVENTS_URL=https://grupo9.example.com/events
# ANALYTICS_API_KEY=
EVENT_WORKER_INTERVAL_MS=30000
EVENT_MAX_ATTEMPTS=5
EVENT_REQUEST_TIMEOUT_MS=10000
